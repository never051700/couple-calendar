# Supabase 프로젝트 설정 (Project Settings > API 에서 복사)
# 이 파일을 복사해 `.env` 로 저장한 뒤 값을 채우세요.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# App Store 제출 전에 실제로 공개된 HTTPS 주소를 입력하세요.
# 비워두면 설정 화면에서 준비 중 안내를 표시합니다.
EXPO_PUBLIC_PRIVACY_POLICY_URL=
EXPO_PUBLIC_SUPPORT_URL=

# Android 원격 푸시를 사용할 때 Firebase에서 받은 파일 경로를 지정하세요.
# EAS에서는 같은 이름의 File 환경 변수로 등록할 수 있습니다.
# GOOGLE_SERVICES_JSON=./google-services.json
